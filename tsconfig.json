{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "lib": ["ES2020"]
  },
  "include": ["service.ts", "nodes/**/*.ts", "gen/**/*.ts", "gen/**/*.js"],
  "exclude": ["node_modules", "dist", "**/*_test.ts", "**/*.test.ts"]
}
